{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/library.schema.json",
  "title": "Library component",
  "description": "A library component of a project",
  "type": "object",
  "required": [ "type", "component", "path", "source-language" ],
  "properties": {
    "type": {
      "const": "library"
    },
    "component": {
      "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/fields/v1/component.schema.json"
    },
    "path": {
      "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/fields/v1/path.schema.json"
    },
    "source-language": {
      "enum": [ "go", "node" ]
    }
  },
  "additionalProperties": false
}
