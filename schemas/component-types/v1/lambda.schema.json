{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/lambda.schema.json",
  "title": "Lambda component",
  "description": "A Lambda component of a project",
  "type": "object",
  "required": [ "type", "subpaths", "source-language" ],
  "properties": {
    "type": {
      "const": "lambda"
    },
    "source-language": {
      "enum": [ "go", "node" ]
    },
    "subpaths": {
      "type": "object",
      "required": [ "src", "build", "infra" ],
      "properties": {
        "src": {
          "description": "The path to the Lambda source code",
          "type": "string"
        },
        "build": {
          "description": "The path for the compiled executable",
          "type": "string"
        },
        "infra": {
          "description": "The path to the Lambda infrastructure",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "deployments": {
      "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/deployments.schema.json"
    }
  },
  "additionalProperties": false
}
