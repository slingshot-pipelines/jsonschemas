{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/github-action.schema.json",
  "title": "GitHub Action component",
  "description": "A GitHub Action component of a project",
  "type": "object",
  "required": [ "component", "type", "path", "source-language" ],
  "properties": {
    "type": {
      "const": "github-action"
    },
    "component": {
      "description": "The name of the component",
      "type": "string"
    },
    "path": {
      "description": "The path of the component",
      "type": "string"
    },
    "source-language": {
      "enum": [ "composite", "node", "docker" ]
    }
  },
  "additionalProperties": false
}
