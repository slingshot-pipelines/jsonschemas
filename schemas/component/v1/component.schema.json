{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/component.schema.json",
  "title": "Component",
  "description": "A component of a project",
  "type": "object",
  "required": [ "type", "component" ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "github-action",
        "json-schemas",
        "lambda",
        "library",
        "s3-website",
        "terraform-modules",
        "terragrunt-infra"
      ]
    },
    "component": {
      "description": "The name of the component",
      "type": "string"
    }
  }
}
