{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/component.schema.json",
  "title": "Component",
  "description": "A component of a project",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "github-action"
          }
        }
      },
      "then": {
        "dependentSchemas": {
          "type": {
            "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component-types/v1/github-action.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "json-schemas"
          }
        }
      },
      "then": {
        "dependentSchemas": {
          "type": {
            "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component-types/v1/json-schemas.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "lambda"
          }
        }
      },
      "then": {
        "dependentSchemas": {
          "type": {
            "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component-types/v1/lambda.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "library"
          }
        }
      },
      "then": {
        "dependentSchemas": {
          "type": {
            "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component-types/v1/library.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "s3-website"
          }
        }
      },
      "then": {
        "dependentSchemas": {
          "type": {
            "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component-types/v1/s3-website.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "terraform-modules"
          }
        }
      },
      "then": {
        "dependentSchemas": {
          "type": {
            "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component-types/v1/terraform-modules.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "terragrunt-infra"
          }
        }
      },
      "then": {
        "dependentSchemas": {
          "type": {
            "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component-types/v1/terragrunt-infra.schema.json"
          }
        }
      }
    }
  ],
  "required": [ "type", "component", "path" ],
  "properties": {
    "type": {
      "enum": [
        "github-action",
        "json-schemas",
        "lambda",
        "library",
        "s3-website",
        "terraform-modules",
        "terragrunt-infra"
      ]
    },
    "component": {
      "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/fields/v1/component.schema.json"
    },
    "path": {
      "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/fields/v1/path.schema.json"
    }
  }
}
