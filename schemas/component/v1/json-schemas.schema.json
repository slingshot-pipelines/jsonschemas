{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/json-schemas.schema.json",
  "title": "JSON Schemas component",
  "description": "A JSON schemas component of a project",
  "type": "object",
  "required": [ "component", "type", "path" ],
  "properties": {
    "type": {
      "const": "json-schemas"
    },
    "component": {
      "description": "The name of the component",
      "type": "string"
    },
    "path": {
      "description": "The path of the component",
      "type": "string"
    }
  },
  "additionalProperties": false
}
