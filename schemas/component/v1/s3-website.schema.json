{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/s3-website.schema.json",
  "title": "S3 Website component",
  "description": "An S3 website component of a project",
  "type": "object",
  "required": [ "component", "type", "path" ],
  "properties": {
    "type": {
      "const": "s3-website"
    },
    "component": {
      "description": "The name of the component",
      "type": "string"
    },
    "path": {
      "description": "The path of the component",
      "type": "string"
    }
  },
  "additionalProperties": false
}
