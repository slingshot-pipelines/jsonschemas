{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/terragrunt-infra.schema.json",
  "title": "Terragrunt Infrastructure component",
  "description": "A Terragrunt infrastructure component of a project",
  "type": "object",
  "required": [ "component", "type", "path" ],
  "properties": {
    "type": {
      "const": "terragrunt-infra"
    },
    "component": {
      "description": "The name of the component",
      "type": "string"
    },
    "path": {
      "description": "The path of the component",
      "type": "string"
    },
    "deployments": {
      "$ref": "https://raw.githubusercontent.com/slingshot-pipelines/jsonschemas/main/schemas/component/v1/deployments.schema.json"
    }
  },
  "additionalProperties": false
}
